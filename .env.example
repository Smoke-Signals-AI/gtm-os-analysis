HUBSPOT_ACCESS_TOKEN=       # HubSpot private app token
ANYSITE_API_KEY=            # Anysite.io API key
ANTHROPIC_API_KEY=          # Anthropic API key

# Concierge chat -> Slack (optional; chat AI still works without these,
# but messages will not be relayed to Slack and the team cannot reply)
SLACK_BOT_TOKEN=            # xoxb-... bot token with chat:write
SLACK_CHANNEL_ID=           # channel where visitor conversations land, e.g. C0123ABCD
SLACK_SIGNING_SECRET=       # used to verify inbound Slack Events API requests

NODE_ENV=production
PORT=3000

# Durable store. REQUIRED in production: without it the app falls back to an
# in-process store, so saved reports/chats/rate-limits are lost on every deploy
# and are not shared across instances (share links, PDFs, and chat then 404).
REDIS_URL=                  # redis://... (Railway: the Redis plugin's connection URL)

# Optional: per-call timeout (ms) for the Anysite LinkedIn API. Lower = faster
# failure/fallback when the upstream is slow. Defaults to 10000.
ANYSITE_TIMEOUT_MS=10000

# Optional: Firecrawl fallback for the website scraper. When set, sites that
# block the plain fetch or render client-side get scraped through Firecrawl's
# headless browser (better research text + catches GTM-injected HubSpot).
# Without a key the scraper just uses the plain fetch, as before.
FIRECRAWL_API_KEY=
FIRECRAWL_TIMEOUT_MS=30000
